{
  "name": "java-openspec",
  "version": "0.5.0",
  "description": "从 Java Spring Cloud 项目自动生成 OpenSpec store 的 CLI 工具",
  "type": "module",
  "bin": {
    "java-openspec": "dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "spec-templates/",
    "README.md",
    "README.zh-CN.md",
    ".env.example"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "java",
    "spring-cloud",
    "openspec",
    "spec",
    "code-analysis",
    "mermaid",
    "documentation",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/overstart/java-openspec.git"
  },
  "author": "overstart",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/xml2js": "^0.4.14"
  },
  "peerDependencies": {
    "bun": ">=1.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "commander": "^15.0.0",
    "js-yaml": "^5.2.1",
    "openai": "^6.46.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "xml2js": "^0.6.2"
  }
}