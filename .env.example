# java-openspec LLM 配置
# 复制此文件为 .env 并填入实际值

# OpenAI API Key (兼容任何 OpenAI-format 服务)
OPENAI_API_KEY=your-api-key-here

# LLM 模型
LLM_MODEL=gpt-4o-mini

# API 端点 (默认 OpenAI，可改为其他兼容服务)
LLM_BASE_URL=https://api.openai.com/v1

# 生成参数
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.3

# --- 火山引擎 Ark 兼容示例 ---
# LLM_MODEL=deepseek-v4-flash
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# --- ACP 模式 (无需 API key，连接已有 agent) ---
# 当 OPENAI_API_KEY 未设置时，使用 ACP_AGENT_CMD 指定的 agent
# 首推 opencode acp --pure (需已安装 opencode，--pure 去掉多余插件)
# ACP_AGENT_CMD=opencode acp --pure
# 其他兼容 agent:
# ACP_AGENT_CMD=claude-code-acp
# ACP_AGENT_CMD=gemini --experimental-acp